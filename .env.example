# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Google Gemini API (free tier from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# InvenTree API
INVENTREE_URL=http://inventree-server:8000
INVENTREE_API_TOKEN=your-inventree-api-token

# Optional: allowed Telegram user IDs (comma-separated, leave empty for no restriction)
ALLOWED_USER_IDS=

# Gemini model fallback chains (comma-separated, first model tried first; falls back on 429)
# GEMINI_MODELS_TEXT=gemini-3.1-flash-lite-preview,gemini-2.5-flash-lite,gemini-2.5-flash
# GEMINI_MODELS_VISION=gemini-2.5-flash,gemini-3.1-flash-lite-preview

# Docker network where InvenTree containers run (default: inventree_default)
# INVENTREE_NETWORK=inventree_default
