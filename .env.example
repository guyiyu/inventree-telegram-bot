# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Google Gemini API (free tier from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# InvenTree API
INVENTREE_URL=http://inventree-server:8000
INVENTREE_SITE_URL=https://inventree.example.com
INVENTREE_API_TOKEN=your-inventree-api-token

# Optional: allowed Telegram user IDs (comma-separated, leave empty for no restriction)
ALLOWED_USER_IDS=

# Gemini model fallback chains (comma-separated, first model tried first; falls back on 429)
# GEMINI_MODELS_TEXT=gemini-flash-lite-latest,gemini-2.5-flash-lite
# GEMINI_MODELS_VISION=gemini-flash-latest,gemini-2.5-flash,gemini-flash-lite-latest

# Docker network where InvenTree containers run (default: inventree_default)
# INVENTREE_NETWORK=inventree_default

# Conversation context budget and compaction settings (defaults shown)
# CONTEXT_BUDGET=32000
# HOT_COMPACTION_THRESHOLD=0.9
# HOT_COMPACTION_KEEP_RAW=5
# IDLE_COMPACTION_THRESHOLD=0.7
# IDLE_COMPACTION_KEEP_RAW=2
# IDLE_TIMEOUT=300
# COMPACTION_MODEL=gemini-flash-lite-latest
